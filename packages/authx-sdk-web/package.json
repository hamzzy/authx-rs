{
  "name": "@authx/sdk-web",
  "version": "0.1.0",
  "description": "Browser token storage and refresh orchestration for authx-rs",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/esm/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "pretest": "npm run build",
    "test": "node --test ./test/*.test.mjs",
    "prepack": "npm run build && npm test",
    "pack:check": "npm pack --dry-run --cache /tmp/authx-npm-cache"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "authx",
    "oauth2",
    "oidc",
    "token",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamzzy/authx-rs.git",
    "directory": "packages/authx-sdk-web"
  },
  "homepage": "https://github.com/hamzzy/authx-rs",
  "bugs": {
    "url": "https://github.com/hamzzy/authx-rs/issues"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
