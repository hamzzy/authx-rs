{
  "name": "@authx/sdk-react",
  "version": "0.1.0",
  "description": "React bindings for authx-rs token clients",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/esm/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "pretest": "npm run build",
    "test": "node --test ./test/*.test.mjs",
    "prepack": "npm run build && npm test",
    "pack:check": "npm pack --dry-run --cache /tmp/authx-npm-cache"
  },
  "peerDependencies": {
    "@authx/sdk-web": "^0.1.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "authx",
    "react",
    "oauth2",
    "oidc"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamzzy/authx-rs.git",
    "directory": "packages/authx-sdk-react"
  },
  "homepage": "https://github.com/hamzzy/authx-rs",
  "bugs": {
    "url": "https://github.com/hamzzy/authx-rs/issues"
  },
  "devDependencies": {
    "@authx/sdk-web": "file:../authx-sdk-web",
    "@testing-library/react": "^16.3.0",
    "jsdom": "^26.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.9.3"
  }
}
