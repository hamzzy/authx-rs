# The Vite dev server proxies /oidc and /auth to the backend,
# so the issuer is the frontend origin from the browser's perspective.
# These values are now optional because the client can read /debug/config at runtime.
VITE_AUTHX_ISSUER=http://localhost:5173
VITE_AUTHX_REDIRECT_URI=http://localhost:5173
# Optional override. If omitted, the backend-provided runtime config is used.
VITE_AUTHX_CLIENT_ID=8a77a9eb-5a1b-4aca-8e0a-f92b7a740366
